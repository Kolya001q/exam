{
  "compilerOptions": {
    "target": "ES2016",
    "module": "CommonJS",
    "rootDir": "./src",           /* Вказує, що весь код лежить в src */
    "outDir": "./dist",           /* Куди збирати готовий JS */
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"],        /* Компілювати тільки файли в папці src */
  "exclude": ["node_modules"]
}